# Development Environment Configuration
# Used for local development with minimal security

DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=udemy_devops
DB_PORT=5432
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# JWT Secrets (insecure defaults - change in staging/prod)
JWT_SECRET=dev_access_secret_change_in_prod
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod

# Service URLs
AUTH_SERVICE_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:8080
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# Feature Flags
ENABLE_CORS=true
ENABLE_METRICS=true
ENABLE_DEBUG_LOGGING=true
